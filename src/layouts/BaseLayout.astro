---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title, description, image, type, publishedDate, modifiedDate, author } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type}
      publishedDate={publishedDate} modifiedDate={modifiedDate} author={author} />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
